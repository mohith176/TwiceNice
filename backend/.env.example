# Server
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/twicenice?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudinary (image hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — the frontend origin allowed to call this API
CLIENT_ORIGIN=http://localhost:5173

# The email that the seed script promotes to admin
ADMIN_EMAIL=admin@twicenice.com
